# Bitcoin Network Configuration
NEXT_PUBLIC_DEFAULT_NETWORK=regtest

# Breez SDK API Key (server-only, fetched at runtime to avoid exposure in client bundle)
BREEZ_API_KEY=

# Custom LNURL domain for Lightning addresses. Leave empty to use Breez default.
# Must be whitelisted by Breez (CNAME to breez.tips) before users can register.
NEXT_PUBLIC_LNURL_DOMAIN=pay.santiagobitdevs.org

# Google OAuth client ID for the Drive backup feature.
# Public (exposed in client bundle by design); abuse is prevented by Authorized
# JavaScript Origins in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=477596796002-p4kg41pnpisk9n3nnek6oi3nqg0s9s1b.apps.googleusercontent.com
